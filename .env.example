# Server
APP_PORT=8080
LOG_LEVEL=info

# Auth
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-please-use-openssl-rand-base64-48

# SQLite database file (relative to working dir inside container)
DB_PATH=./data/app.db

# Initial admin (created automatically on first run if no admins exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Web Push (VAPID) — уведомления о вызове при закрытом приложении.
# Сгенерировать пару ключей: см. SELF_HOSTING.
# VAPID_SUBJECT — контакт оператора: валидный https URL или mailto.
# НЕ используйте .local-домен: Apple Web Push отвергает такой токен (403 BadJwtToken), iOS-пуш не дойдёт.
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=https://example.com
